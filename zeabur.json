{
  "$schema": "https://zeabur.com/zeabur.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "env": {
      "PYTHON_VERSION": "3.10"
    }
  },
  "deploy": {
    "startCommand": "pip install -r requirements.txt && gunicorn --bind 0.0.0.0:$PORT app:app",
    "restartPolicy": "on-failure"
  }
}
